from __future__ import annotations

from typing import Any
from adobe.core import BrokerClient
from adobe.core.session import HostSession

class PremiereSession(HostSession):
    def __init__(self, client: BrokerClient | None = ...) -> None: ...


class Premiere(PremiereSession):
    def __init__(self, *, broker_url: str | None = ..., token: str | None = ..., target: str = "default", timeout: float = ..., client: BrokerClient | None = ...) -> None: ...
    @property
    def version(self) -> str: ...
    @property
    def active_project(self) -> ProjectProxy | None: ...
    @property
    def activeProject(self) -> ProjectProxy | None: ...
    @property
    def project(self) -> ProjectProxy | None: ...
    @property
    def sequences(self) -> list[SequenceProxy]: ...
    @property
    def active_sequence(self) -> SequenceProxy | None: ...
    @property
    def activeSequence(self) -> SequenceProxy | None: ...


class PremiereApp:
    @property
    def version(self) -> str: ...
    @property
    def active_project(self) -> ProjectProxy | None: ...
    @property
    def activeProject(self) -> ProjectProxy | None: ...
    @property
    def project(self) -> ProjectProxy | None: ...
    @property
    def sequences(self) -> list[SequenceProxy]: ...
    @property
    def active_sequence(self) -> SequenceProxy | None: ...
    @property
    def activeSequence(self) -> SequenceProxy | None: ...


class ProjectProxy:
    @property
    def id(self) -> Any: ...
    @property
    def guid(self) -> str | None: ...
    @property
    def name(self) -> str | None: ...
    @property
    def path(self) -> str | None: ...
    @property
    def item_count(self) -> int: ...
    @property
    def itemCount(self) -> int: ...
    @property
    def active_sequence(self) -> SequenceProxy | None: ...
    @property
    def activeSequence(self) -> SequenceProxy | None: ...
    @property
    def sequences(self) -> list[SequenceProxy]: ...
    def get_sequence(self, *args: Any, **kwargs: Any) -> SequenceProxy | None: ...
    def getSequence(self, *args: Any, **kwargs: Any) -> SequenceProxy | None: ...


class SequenceProxy:
    @property
    def id(self) -> Any: ...
    @property
    def sequence_id(self) -> Any: ...
    @property
    def sequenceId(self) -> Any: ...
    @property
    def name(self) -> str | None: ...
    @property
    def duration(self) -> Any: ...
    @property
    def timebase(self) -> Any: ...
    @property
    def typename(self) -> str | None: ...
    @property
    def video_tracks(self) -> list[TrackProxy]: ...
    @property
    def videoTracks(self) -> list[TrackProxy]: ...
    @property
    def audio_tracks(self) -> list[TrackProxy]: ...
    @property
    def audioTracks(self) -> list[TrackProxy]: ...
    @property
    def markers(self) -> list[MarkerProxy]: ...
    @property
    def selected_clips(self) -> list[ClipProxy]: ...
    @property
    def selectedClips(self) -> list[ClipProxy]: ...
    def create_marker(self, *args: Any, **kwargs: Any) -> MarkerProxy: ...
    def createMarker(self, *args: Any, **kwargs: Any) -> MarkerProxy: ...


