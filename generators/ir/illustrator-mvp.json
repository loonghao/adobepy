{
  "host": "illustrator",
  "version": "0.1.0",
  "namespaces": [
    {
      "name": "app",
      "methods": [{"name": "getVersion", "returns": "str"}],
      "properties": [{"name": "active_document", "type": "Document | None", "source": "document.getActive"}]
    },
    {"name": "document", "methods": [{"name": "getActive", "returns": "Document | None"}]},
    {"name": "raw", "methods": [{"name": "evalExtendScript", "returns": "Any", "raw": true}]}
  ],
  "proxies": [
    {
      "name": "DocumentProxy",
      "properties": [
        {"name": "name", "type": "str | None"},
        {"name": "path", "type": "str | None"},
        {"name": "width", "type": "Any"},
        {"name": "height", "type": "Any"}
      ]
    }
  ]
}
